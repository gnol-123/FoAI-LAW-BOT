# ── Secrets & credentials ──────────────────────────────────────────────────
# Firebase service account keys — NEVER commit these
*firebase-adminsdk*.json
serviceAccountKey.json
*.json.key

# Environment files with real values
# .env.example files are safe to commit — they have no real values
.env

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ── Generated / runtime data ───────────────────────────────────────────────
# Whoosh full-text index — large binary, rebuilt automatically on app startup
backend/whoosh_index/

# Scraper — locally downloaded PDFs before upload (large, not source code)
scraper/downloads/

# ── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Tool session data ───────────────────────────────────────────────────────
.claude/
.agents/
skills-lock.json
.playwright-mcp/
